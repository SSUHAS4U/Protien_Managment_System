# Root & IDE ignores
.DS_Store
.idea/
.vscode/
*.log
/protein_temp/

# Frontend ignores
/frontend/node_modules/
/frontend/build/
/frontend/.pnp
/frontend/.pnp.js
/frontend/coverage/
/frontend/.env*.local
/frontend/*-debug.log*
/frontend/*-error.log*

# Secrets / environment (NEVER commit these)
.env
.env.local
*.env
/backend/.env
/frontend/.env

# Backend ignores
/backend/target/
/backend/.apt_generated
/backend/.classpath
/backend/.factorypath
/backend/.project
/backend/.settings
/backend/.springBeans
/backend/.sts4-cache
/backend/*.iws
/backend/*.iml
/backend/*.ipr
