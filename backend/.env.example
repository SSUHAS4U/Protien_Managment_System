# ==============================================================
# Copy this file to `.env` and fill in real values for local dev.
# On Render, set these as Environment Variables in the dashboard.
# `.env` is gitignored — NEVER commit real secrets.
# ==============================================================

# --- Database (Supabase Postgres) ---
DB_URL=jdbc:postgresql://<host>:5432/postgres
DB_USERNAME=<supabase-user>
DB_PASSWORD=<supabase-password>

# --- Spoonacular (https://spoonacular.com/food-api) ---
SPOONACULAR_API_KEY=<spoonacular-key>

# --- Groq (chatbot LLM, https://console.groq.com) ---
GROQ_API_KEY=<groq-key>

# --- API Ninjas (exercise catalog + calories burned, https://api-ninjas.com) ---
EXERCISE_API_KEY=<api-ninjas-key>

# --- CORS: comma-separated allowed origins (no wildcard in prod) ---
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# --- Render automation (used by scripts/render-sync-env.mjs, NOT uploaded) ---
# Create an API key at https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=<render-api-key>
RENDER_SERVICE_ID=
RENDER_SERVICE_NAME=Protien_Managment_System

# --- UptimeRobot keep-warm (used by scripts/uptimerobot-setup.mjs, NOT uploaded) ---
UPTIMEROBOT_API_KEY=<uptimerobot-main-api-key>
HEALTH_URL=https://your-backend.onrender.com/health
